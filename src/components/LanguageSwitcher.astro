---
import { type Lang, languages, getLocalePath } from '../i18n';

interface Props {
  lang: Lang;
  currentPath?: string;
}

const { lang, currentPath = '' } = Astro.props;
---

<div class="lang-switcher">
  {Object.entries(languages).map(([code, label]) => (
    <a
      href={getLocalePath(code as Lang, currentPath)}
      class:list={['lang-link', { active: code === lang }]}
    >
      {label}
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
  }

  .lang-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .lang-link:hover {
    color: var(--color-text);
    background: var(--color-bg-secondary);
  }

  .lang-link.active {
    color: var(--color-accent);
    font-weight: 600;
  }
</style>

---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<Base lang={lang}>
  <section class="hero">
    <h1>Jacob Chuang</h1>
    <p class="intro">
      Hi, I'm Jacob — a trilingual lawyer fluent in Chinese, English, and Japanese.
      I share my observations and decision analysis at the intersection of law, business, and technology.
      I believe good decisions come from deep thinking, and writing is my best way to organize my thoughts.
    </p>
  </section>

  <hr />

  <section class="about-me">
    <h2>About Me</h2>
    <p>There are two main types of articles on this site:</p>
    <p>
      <strong>"Decision & Positioning"</strong> — Whether it's a company's strategic choice or an individual's life positioning, there are always compelling stories and logic worth exploring.
    </p>
    <p>
      <strong>"Legal Strategy"</strong> — Focused on how to achieve business objectives or personal planning through legal strategy, including legal opinion feasibility analysis and in-depth legal analysis.
    </p>
  </section>

  <hr />

  <section class="education">
    <ul>
      <li>LL.B., National Taiwan University</li>
      <li>LL.M., National Taiwan University</li>
      <li>LL.M., Hitotsubashi University, Japan</li>
    </ul>
  </section>

  <hr />

  <section class="contact">
    <h2>Contact</h2>
    <ul>
      <li>LinkedIn: <a href="https://www.linkedin.com/in/hungkaichuang/" target="_blank" rel="noopener">hungkaichuang</a></li>
    </ul>
  </section>

  <section class="newsletter">
    <h2>{t('home.subscribe')}</h2>
    <p>{t('home.subscribe.desc')}</p>
    <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>
    <form
      action="https://app.kit.com/forms/6662889/subscriptions"
      class="formkit-form"
      method="post"
      data-sv-form="6662889"
      data-uid="222f694403"
      data-format="inline"
      data-version="5"
    >
      <div class="newsletter-fields">
        <input type="email" name="email_address" placeholder="your@email.com" required class="newsletter-input" />
        <button type="submit" class="newsletter-button">Subscribe</button>
      </div>
    </form>
  </section>
</Base>

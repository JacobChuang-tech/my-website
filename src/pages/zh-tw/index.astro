---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';

const lang = 'zh-tw' as const;
const t = useTranslations(lang);
---

<Base lang={lang}>
  <!-- Hero: 個人介紹，參考 pjwu.me 風格 -->
  <section class="hero">
    <h1>Jacob Chuang 莊閎凱</h1>
    <p class="intro">
      Hi，我是 Jacob，一名精通中文、英文、日文三種語言的律師。
      我會在這裡分享我對法律、商業與科技交叉領域的觀察、決策分析，以及我體驗不同事物後的心得。
    </p>
  </section>

  <hr />

  <!-- 關於我 -->
  <section class="about-me">
    <h2>關於我</h2>
    <p>
      我是一名三語律師（中文、英文、日文），專注在法律、商業與科技的交叉領域。
      我相信好的決策來自於深度的思考，而寫作是我整理思路最好的方式。
    </p>
    <p>
      我對「決策」與「定位」這兩個主題特別著迷——不管是企業的戰略選擇，
      還是個人的人生定位，背後都有值得深入探討的邏輯與故事。
    </p>
  </section>

  <hr />

  <!-- 聯繫方式 -->
  <section class="contact">
    <h2>聯繫方式</h2>
    <p>如果你對我的內容有任何想法，或者想要聊聊，歡迎透過以下方式聯繫我：</p>
    <ul>
      <li>LinkedIn：<a href="https://www.linkedin.com/in/hungkaichuang/" target="_blank" rel="noopener">hungkaichuang</a></li>
    </ul>
  </section>

  <!-- 訂閱電子報 -->
  <section class="newsletter">
    <h2>{t('home.subscribe')}</h2>
    <p>{t('home.subscribe.desc')}</p>
    <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>
    <form
      action="https://app.kit.com/forms/6662889/subscriptions"
      class="formkit-form"
      method="post"
      data-sv-form="6662889"
      data-uid="222f694403"
      data-format="inline"
      data-version="5"
    >
      <div class="newsletter-fields">
        <input type="email" name="email_address" placeholder="your@email.com" required class="newsletter-input" />
        <button type="submit" class="newsletter-button">訂閱</button>
      </div>
    </form>
  </section>
</Base>

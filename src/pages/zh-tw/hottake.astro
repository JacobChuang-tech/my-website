---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const lang = 'zh-tw' as const;

const allHottakes = await getCollection('hottake');
const hottakes = allHottakes
  .filter(h => h.data.lang === 'zh-tw')
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const renderedHottakes = await Promise.all(
  hottakes.map(async (h) => {
    const { Content } = await render(h);
    return { data: h.data, Content };
  })
);
---

<Base lang={lang} title="Hot Take">
  <section class="hottake-hero">
    <h1>Hot Take</h1>
    <p class="hottake-intro">短想法、觀察、和不吐不快的觀點。</p>
  </section>

  <div class="hottake-feed">
    {renderedHottakes.length === 0 ? (
      <p class="hottake-empty">尚未發布任何 Hot Take。敬請期待！</p>
    ) : (
      renderedHottakes.map(({ data, Content }) => (
        <article class="hottake-card">
          <time datetime={data.pubDate.toISOString().split('T')[0]}>
            {data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <div class="hottake-content">
            <Content />
          </div>
        </article>
      ))
    )}
  </div>
</Base>

<style>
  .hottake-hero { padding: 2rem 0 1.5rem; margin-bottom: 1.5rem; }
  .hottake-hero h1 { font-size: 2.2rem; margin-bottom: 1rem; }
  .hottake-intro { color: var(--color-text-secondary); line-height: 1.8; }
  .hottake-feed { display: flex; flex-direction: column; gap: 0; }
  .hottake-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .hottake-card:first-child { border-top: 1px solid var(--color-border); }
  .hottake-card time {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }
  .hottake-content {
    font-size: 1.05rem;
    line-height: 1.8;
  }
  .hottake-content :global(p) { margin-bottom: 0.5rem; }
  .hottake-content :global(p:last-child) { margin-bottom: 0; }
  .hottake-content :global(a) { color: var(--color-accent); }
  .hottake-content :global(strong) { color: var(--color-text); }
  .hottake-empty { color: var(--color-text-secondary); font-style: italic; }
</style>

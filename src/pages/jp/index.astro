---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';

const lang = 'jp' as const;
const t = useTranslations(lang);
---

<Base lang={lang}>
  <section class="hero">
    <h1>Jacob Chuang（莊閎凱）</h1>
    <p class="intro">
      はじめまして、Jacobです。中国語、英語、日本語の三言語に精通する弁護士です。
      法律、ビジネス、テクノロジーの交差点における観察や意思決定の分析をここで共有しています。
      良い意思決定は深い思考から生まれると信じており、執筆は考えを整理する最善の方法です。
    </p>
  </section>

  <hr />

  <section class="about-me">
    <h2>私について</h2>
    <p>本サイトには主に二種類の記事があります：</p>
    <p>
      <strong>「意思決定とポジショニング」</strong>企業の戦略的選択であれ、個人の人生のポジショニングであれ、その背後には探求に値する論理とストーリーがあります。
    </p>
    <p>
      <strong>「リーガルストラテジー」</strong>法律戦略を通じてビジネス目的や個人の計画をどのように達成するかに焦点を当て、法律意見の実現可能性分析や法律の深い分析を行います。
    </p>
  </section>

  <hr />

  <section class="education">
    <ul>
      <li>国立台湾大学法学部 学士</li>
      <li>国立台湾大学法学部 修士</li>
      <li>一橋大学法学研究科 修士</li>
    </ul>
  </section>

  <hr />

  <section class="contact">
    <h2>連絡先</h2>
    <ul>
      <li>LinkedIn：<a href="https://www.linkedin.com/in/hungkaichuang/" target="_blank" rel="noopener">hungkaichuang</a></li>
    </ul>
  </section>

  <section class="newsletter">
    <h2>{t('home.subscribe')}</h2>
    <p>{t('home.subscribe.desc')}</p>
    <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>
    <form
      action="https://app.kit.com/forms/6662889/subscriptions"
      class="formkit-form"
      method="post"
      data-sv-form="6662889"
      data-uid="222f694403"
      data-format="inline"
      data-version="5"
    >
      <div class="newsletter-fields">
        <input type="email" name="email_address" placeholder="your@email.com" required class="newsletter-input" />
        <button type="submit" class="newsletter-button">登録</button>
      </div>
    </form>
  </section>
</Base>

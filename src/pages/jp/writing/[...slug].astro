---
import Base from '../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allWriting = await getCollection('writing');
  const articles = allWriting.filter(a => a.data.lang === 'jp');
  return articles.map(article => ({
    params: { slug: article.id.replace('jp/', '') },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const lang = 'jp' as const;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.description,
  "datePublished": article.data.pubDate.toISOString(),
  "inLanguage": "ja",
  "url": canonicalURL.href,
  "articleSection": article.data.category,
  "keywords": article.data.tags,
  "author": {
    "@type": "Person",
    "@id": "https://hungkaichuang.com/#person",
    "name": "Jacob Chuang",
    "alternateName": "莊閎凱",
    "jobTitle": "Lawyer",
    "url": "https://hungkaichuang.com",
    "knowsLanguage": ["zh-TW", "en", "ja"],
    "description": "Trilingual lawyer focused on decision analysis and positioning strategy at the intersection of law, business, and technology.",
    "alumniOf": [
      { "@type": "CollegeOrUniversity", "name": "Hitotsubashi University" },
      { "@type": "CollegeOrUniversity", "name": "National Taiwan University" }
    ]
  },
  "publisher": {
    "@type": "Person",
    "@id": "https://hungkaichuang.com/#person",
    "name": "Jacob Chuang"
  }
};
---

<Base lang={lang} title={article.data.title} description={article.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article class="article-detail">
    <header class="article-header">
      <div class="article-meta">
        {article.data.tags.map(tag => (
          <span class="article-tag">{tag}</span>
        ))}
        <time datetime={article.data.pubDate.toISOString().split('T')[0]}>
          {article.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      <h1>{article.data.title}</h1>
    </header>
    <div class="article-content">
      <Content />
    </div>
    <footer class="article-footer">
      <a href="/jp/writing" class="back-link">&larr; 記事一覧に戻る</a>
    </footer>
  </article>
</Base>

<style>
  .article-detail {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .article-header h1 {
    font-size: 1.8rem;
    line-height: 1.4;
    margin-top: 0.75rem;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }
  .article-tag {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    background: var(--color-bg-secondary);
    border-radius: 4px;
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 500;
  }
  .article-content {
    line-height: 1.9;
    font-size: 1.05rem;
  }
  .article-content :global(h2) {
    font-size: 1.4rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .article-content :global(h3) {
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .article-content :global(ul), .article-content :global(ol) {
    padding-left: 1.5rem;
    margin: 1rem 0;
  }
  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }
  .article-content :global(strong) {
    color: var(--color-text);
  }
  .article-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  .article-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .back-link {
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .back-link:hover {
    text-decoration: underline;
  }
</style>

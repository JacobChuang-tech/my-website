---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const lang = 'jp' as const;

const allWriting = await getCollection('writing');
const allArticles = allWriting.filter(a => a.data.lang === 'jp');
const articles = allArticles.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const mainTags = ['決策與定位', '法律策略'];
const allTags = mainTags;
---

<Base lang={lang} title="Writing">
  <section class="writing-hero">
    <h1>Writing</h1>
    <p class="writing-intro">
      ここでの執筆は、読書や観察、何かを実践した後に感じたことを記録することが多いです。
      ほとんどの場合、日記のようなものですが、書いているうちに自分の心の中のかすかな声をより明確に理解できるようになります。
    </p>
    <p class="writing-intro">
      自分が確信していることや疑問に思っていることについても、より確信が持てるようになり、時折振り返ると新たな気づきがあります。
    </p>
  </section>

  <div class="tag-filter" role="tablist">
    <button class="tag-btn active" data-tag="all" role="tab" aria-selected="true">すべて</button>
    {allTags.map(tag => (
      <button class="tag-btn" data-tag={tag} role="tab" aria-selected="false">{tag}</button>
    ))}
  </div>

  <div class="article-list">
    {articles.map(article => (
      <article class="article-card" data-tags={JSON.stringify(article.data.tags)}>
        <h3><a href={`/jp/writing/${article.id.replace('jp/', '')}`}>{article.data.title}</a></h3>
        <div class="article-meta">
          {article.data.tags.filter(tag => mainTags.includes(tag)).map(tag => (
            <span class="article-tag">{tag}</span>
          ))}
          <time datetime={article.data.pubDate.toISOString().split('T')[0]}>
            {article.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        <p>{article.data.description}</p>
      </article>
    ))}
  </div>
</Base>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.tag-btn');
    const articles = document.querySelectorAll('.article-card[data-tags]');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        const selectedTag = btn.getAttribute('data-tag');
        articles.forEach(article => {
          const tags = JSON.parse(article.getAttribute('data-tags') || '[]');
          (article as HTMLElement).style.display = (selectedTag === 'all' || tags.includes(selectedTag)) ? '' : 'none';
        });
      });
    });
  });
</script>

<style>
  .writing-hero { padding: 2rem 0 1.5rem; margin-bottom: 1.5rem; }
  .writing-hero h1 { font-size: 2.2rem; margin-bottom: 1rem; }
  .writing-intro { color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 0.5rem; }
  .tag-filter { display: flex; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .tag-btn { padding: 0.4rem 1rem; border: 1px solid var(--color-border); border-radius: 20px; background: var(--color-bg); color: var(--color-text-secondary); font-size: 0.9rem; cursor: pointer; transition: all 0.2s; font-family: var(--font-sans); }
  .tag-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .tag-btn.active { background: var(--color-accent); color: #fff; border-color: var(--color-accent); }
  .article-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
  .article-tag { display: inline-block; padding: 0.15rem 0.6rem; background: var(--color-bg-secondary); border-radius: 4px; font-size: 0.8rem; color: var(--color-accent); font-weight: 500; }
</style>
